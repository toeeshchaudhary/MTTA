{
  "name": "mtta-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Deprecated desktop wrapper for toeesh.network admin. Use the web /admin editor as the primary studio.",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs && electron dist/main.js --no-sandbox",
    "install-app": "bash install.sh",
    "dist": "node esbuild.mjs && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2"
  },
  "trustedDependencies": ["electron", "esbuild", "electron-builder"]
}
