---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import SignageTile from '../components/SignageTile.astro';
import { getCollection } from 'astro:content';
import { LINES, NAV } from '../lib/lines';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = 'toeesh — home for everything I do and want to do.' } = Astro.props;
const fullTitle = title ? `${title} · toeesh` : 'toeesh';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';

// recent activity for the sidebar
const writing = await getCollection('writing', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
const projects = await getCollection('projects', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
const recent = [
  ...writing.map((p) => ({ line: 'writing' as const, title: p.data.title, href: `/writing/${p.id}`, date: p.data.date })),
  ...projects.map((p) => ({ line: 'projects' as const, title: p.data.title, href: `/projects/${p.id}`, date: p.data.date })),
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="color-scheme" content="dark light" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {/* set theme before paint to avoid a flash (default = black) */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
        } catch {}
      })();
    </script>
  </head>
  <body>
    <div class="app" id="app">
      {/* mobile top bar */}
      <header class="topbar">
        <a class="wm" href="/">toeesh<span style="color:var(--mta-yellow)">●</span></a>
        <button class="sb-toggle" type="button" data-nav-toggle aria-label="Toggle menu">menu</button>
      </header>

      <aside class="sidebar" id="sidebar">
        <a class="sb-brand" href="/">
          <span class="bullet" style="background:var(--mta-shuttle);color:#fff;width:1.8rem;height:1.8rem;font-size:0.9rem">S</span>
          <span>
            <span class="wm">toeesh</span><br />
            <span class="sb-tag">transit authority</span>
          </span>
        </a>

        <nav class="sb-group" aria-label="Sections">
          <p class="sb-section">▸ lines</p>
          {
            NAV.map((line) => (
              <SignageTile
                href={line.href}
                title={line.label}
                sub={line.dest}
                current={path === line.href}
                bullets={[{ glyph: line.bullet, color: line.color, text: line.text }]}
              />
            ))
          }
        </nav>

        {
          recent.length > 0 && (
            <div class="sb-group">
              <p class="sb-section">▸ recent</p>
              {recent.map((r) => {
                const line = LINES[r.line];
                return (
                  <SignageTile
                    href={r.href}
                    title={r.title}
                    clip
                    bullets={[{ glyph: line.bullet, color: line.color, text: line.text }]}
                  />
                );
              })}
            </div>
          )
        }

        <div class="sb-spacer"></div>

        <div class="sb-controls">
          <ThemeToggle />
        </div>
        <p class="sb-foot">toeesh transit authority · {new Date().getFullYear()}<br />helvetica · the grid</p>
      </aside>

      <main class="main">
        <div class="main-inner">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const app = document.getElementById('app');
      document.querySelector('[data-nav-toggle]')?.addEventListener('click', () => {
        app?.classList.toggle('nav-open');
      });
      // close drawer when a link inside the sidebar is tapped
      document.getElementById('sidebar')?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) app?.classList.remove('nav-open');
      });
      // tap the scrim to close
      app?.addEventListener('click', (e) => {
        if (e.target === app && app.classList.contains('nav-open')) app.classList.remove('nav-open');
      });
    </script>
  </body>
</html>
