---
import Base from './Base.astro';
import RouteBullet from '../components/RouteBullet.astro';
import type { Line } from '../lib/lines';

interface Props {
  line: Line;
  title?: string; // overrides the line label as the H1
  kicker?: string;
  description?: string;
}
const { line, title, kicker, description } = Astro.props;
const heading = title ?? line.label;
---

<Base title={heading} description={description}>
  <header>
    {kicker && <p class="kicker">▸ {kicker}</p>}
    <div class="page-head">
      <RouteBullet glyph={line.bullet} color={line.color} text={line.text} size="2.2rem" />
      <h1>{heading}</h1>
    </div>
    <div class="line-bar" style={`background:${line.color}`}></div>
  </header>

  <slot />

  <a class="back" href="/">back to the network</a>
</Base>
