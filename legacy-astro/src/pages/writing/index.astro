---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import SignageTile from '../../components/SignageTile.astro';
import { LINES } from '../../lib/lines';

const posts = (await getCollection('writing', ({ data }) => (import.meta.env.PROD ? !data.draft : true)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const bull = [{ glyph: LINES.writing.bullet, color: LINES.writing.color, text: LINES.writing.text }];
---

<Page line={LINES.writing} kicker="the 1 line · local & express" description="Writing and rants by toeesh.">
  <p style="max-width:52ch;color:var(--ink-soft);margin:0 0 2rem">
    Every stop is something I wrote down. Some are stations, some are just where
    the train paused for a minute.
  </p>

  {
    posts.length === 0 ? (
      <p style="color:var(--ink-soft)">No posts yet — first train pending.</p>
    ) : (
      <ul class="tiles">
        {posts.map((p) => (
          <li class="tile-row">
            <SignageTile href={`/writing/${p.id}`} title={p.data.title} lg bullets={bull} />
            <div class="tile-meta">
              <span>{fmt(p.data.date)}</span>
              {p.data.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            {p.data.description && <p class="tile-desc">{p.data.description}</p>}
          </li>
        ))}
      </ul>
    )
  }
</Page>
