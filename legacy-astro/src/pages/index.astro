---
import Base from '../layouts/Base.astro';
import NetworkView from '../components/NetworkView.astro';
import StationCard from '../components/cards/StationCard.astro';
import MetroCard from '../components/cards/MetroCard.astro';
import TicketCard from '../components/cards/TicketCard.astro';
import WayfindCard from '../components/cards/WayfindCard.astro';
import { LINES } from '../lib/lines';

const b = (k: string) => [{ glyph: LINES[k].bullet, color: LINES[k].color, text: LINES[k].text }];
---

<Base>
  <header class="hero">
    <p class="kicker">▸ toeesh transit authority — est. 2026</p>
    <h1 class="specimen">the<br />network</h1>
    <p class="lede">
      home for everything I do and everything I want to do — a connected map of
      my writing, projects, and obsessions. ride a line. flip to the graph.
      mind the gap.
    </p>
  </header>

  <NetworkView />

  <section class="bento" aria-label="Stations & cards" style="margin-top:1.5rem">
    <StationCard href={LINES.writing.href} name="writing" sub="rants & notes" tone="white" bullets={b('writing')} />
    <StationCard href={LINES.projects.href} name="projects" sub="under construction" tone="black" bullets={b('projects')} />
    <MetroCard />

    <StationCard href={LINES.likes.href} name="likes" sub="the good stuff" tone="black" bullets={b('likes')} />
    <StationCard href={LINES.now.href} name="now" sub="right now" tone="white" bullets={b('now')} />
    <TicketCard />
    <WayfindCard />
  </section>

  <section class="about">
    <p class="kicker">▸ about this stop</p>
    <p>
      I'm toeesh. I tinker with my Linux desktop more than is reasonable, like
      clean signage and clean systems, and keep a running list of things worth
      caring about. Everything here is mine. Nothing here tracks you.
    </p>
  </section>
</Base>

<style>
  .hero { margin-bottom: 1.5rem; }
  .specimen { margin: 0.2rem 0 1.1rem; }
  .lede { max-width: 48ch; color: var(--ink-soft); font-size: 1.05rem; }
  .about { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--line); max-width: 56ch; }
  .about p:not(.kicker) { margin: 0; }
</style>
