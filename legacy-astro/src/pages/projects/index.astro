---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import SignageTile from '../../components/SignageTile.astro';
import { LINES } from '../../lib/lines';

const projects = (await getCollection('projects', ({ data }) => (import.meta.env.PROD ? !data.draft : true)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const bull = [{ glyph: LINES.projects.bullet, color: LINES.projects.color, text: LINES.projects.text }];
---

<Page line={LINES.projects} kicker="the 7 line · to anywhere" description="Things toeesh is building.">
  <p style="max-width:52ch;color:var(--ink-soft);margin:0 0 2rem">
    In service, under construction, or quietly retired to the yard. Each stop is
    something I made.
  </p>

  {
    projects.length === 0 ? (
      <p style="color:var(--ink-soft)">No projects on the board yet.</p>
    ) : (
      <ul class="tiles">
        {projects.map((p) => (
          <li class="tile-row">
            <SignageTile href={`/projects/${p.id}`} title={p.data.title} lg bullets={bull} />
            <div class="tile-meta">
              <span>{fmt(p.data.date)}</span>
              <span class={`status-pill status-${p.data.status}`}>{p.data.status}</span>
            </div>
            {p.data.description && <p class="tile-desc">{p.data.description}</p>}
          </li>
        ))}
      </ul>
    )
  }
</Page>
