---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { LINES } from '../../lib/lines';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { status, link, repo } = project.data;
---

<Page line={LINES.projects} title={project.data.title} kicker="the 7 line" description={project.data.description}>
  <p style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;margin:-1rem 0 2rem">
    <span class={`status-pill status-${status}`}>{status}</span>
    {link && <a href={link} class="tag">visit ↗</a>}
    {repo && <a href={repo} class="tag">source ↗</a>}
  </p>
  <article class="prose">
    <Content />
  </article>
</Page>
