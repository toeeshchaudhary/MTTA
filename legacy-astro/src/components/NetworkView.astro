---
// Wraps the hand-laid transit MAP + the interactive GRAPH behind a segmented
// [ MAP ][ graph ] toggle. MAP is default; the graph lazily boots on first
// reveal (it dispatches `network:graph-show`, which GraphMap listens for).
import TransitMap from './TransitMap.astro';
import GraphMap from './GraphMap.astro';
---

<section class="netview" data-view="map" aria-label="The network">
  <div class="netview-bar">
    <p class="mono" style="margin:0">▸ the network</p>
    <div class="seg" role="tablist" aria-label="View">
      <button class="seg-btn is-on" type="button" data-view-btn="map" role="tab" aria-selected="true">map</button>
      <button class="seg-btn" type="button" data-view-btn="graph" role="tab" aria-selected="false">graph</button>
    </div>
  </div>

  <div class="netview-panes">
    <div class="pane pane-map" data-pane="map"><TransitMap /></div>
    <div class="pane pane-graph" data-pane="graph" hidden><GraphMap /></div>
  </div>
</section>

<script>
  const view = document.querySelector<HTMLElement>('.netview');
  if (view) {
    const btns = view.querySelectorAll<HTMLButtonElement>('[data-view-btn]');
    const panes = view.querySelectorAll<HTMLElement>('[data-pane]');
    const set = (v: string) => {
      view.dataset.view = v;
      btns.forEach((b) => {
        const on = b.dataset.viewBtn === v;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-selected', String(on));
      });
      panes.forEach((p) => (p.hidden = p.dataset.pane !== v));
      try { localStorage.setItem('netview', v); } catch {}
      if (v === 'graph') window.dispatchEvent(new Event('network:graph-show'));
    };
    let stored: string | null = null;
    try { stored = localStorage.getItem('netview'); } catch {}
    if (stored === 'graph') set('graph');
    btns.forEach((b) => b.addEventListener('click', () => set(b.dataset.viewBtn || 'map')));
  }
</script>

<style>
  .netview-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
  .seg { display: inline-flex; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
  .seg-btn {
    font: inherit; font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.1em;
    background: transparent; color: var(--ink-soft); border: 0; padding: 0.4rem 0.8rem; cursor: pointer;
  }
  .seg-btn + .seg-btn { border-left: 1px solid var(--line); }
  .seg-btn.is-on { background: var(--ink); color: var(--bg); }
  .pane[hidden] { display: none; }
</style>
