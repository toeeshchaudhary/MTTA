---
// A big MTA station-name card (image 4): station name + route bullets.
import type { TileBullet } from '../SignageTile.astro';

interface Props {
  href: string;
  name: string;
  bullets: TileBullet[];
  sub?: string;
  tone?: 'white' | 'black';
  span2?: boolean;
}
const { href, name, bullets, sub, tone = 'black', span2 = false } = Astro.props;
---

<a class:list={['card', 'scard', tone, { span2 }]} href={href}>
  <span class="sname">{name}</span>
  <span class="srow">
    {bullets.map((b) => <span class="bullet" style={`background:${b.color};color:${b.text ?? '#fff'}`}>{b.glyph}</span>)}
    {sub && <span class="ssub">{sub}</span>}
  </span>
</a>
