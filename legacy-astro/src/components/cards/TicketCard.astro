---
// "Single Ticket" card (image 4) — surfaces the latest writing post as a
// transit ticket. White card, route bullet + 60', dashed tear edge.
import { getCollection } from 'astro:content';
import { LINES } from '../../lib/lines';

const writing = (await getCollection('writing', ({ data }) => (import.meta.env.PROD ? !data.draft : true)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = writing[0];
const l = LINES.writing;
const href = latest ? `/writing/${latest.id}` : '/writing';
const title = latest ? latest.data.title : 'first train pending';
---

<a class="ticket" href={href}>
  <div class="ticket-top">
    <span class="ticket-head">
      <span class="bullet" style={`background:${l.color};color:${l.text}`}>{l.bullet}</span>
      <span class="ticket-min">60′</span>
    </span>
    <span class="ticket-mta">▣ MTA</span>
  </div>
  <div class="ticket-body">
    <span class="ticket-kind">Single Ticket</span>
    <span class="ticket-title">{title}</span>
  </div>
  <div class="ticket-foot">latest dispatch · valid on all toeesh lines</div>

  <style>
    .ticket {
      position: relative; display: flex; flex-direction: column; justify-content: space-between;
      background: #f4f4f4; color: #0a0a0a; border-radius: 16px; padding: 1rem 1.1rem 1.4rem;
      min-height: 132px; text-decoration: none; overflow: hidden;
    }
    .ticket-top { display: flex; align-items: center; justify-content: space-between; }
    .ticket-head { display: inline-flex; align-items: center; gap: 0.5rem; }
    .ticket .bullet { width: 1.6em; height: 1.6em; }
    .ticket-min { font-family: var(--font-mono); font-weight: 700; font-size: 0.8rem; }
    .ticket-mta { font-family: var(--font-mono); font-size: 0.6rem; color: #555; }
    .ticket-body { margin: 0.6rem 0; }
    .ticket-kind { display: block; font-family: var(--font-mono); font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: #555; }
    .ticket-title { display: block; font-weight: 700; font-size: 1.15rem; letter-spacing: -0.015em; line-height: 1.05; margin-top: 0.2rem; }
    .ticket:hover .ticket-title { text-decoration: underline; }
    .ticket-foot { font-family: var(--font-mono); font-size: 0.56rem; text-transform: uppercase; letter-spacing: 0.08em; color: #555; padding-top: 0.7rem; border-top: 2px dashed #bbb; }
  </style>
</a>
