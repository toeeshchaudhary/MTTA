---
// black (brutalist) <-> white (Swiss) toggle. Default is black. Persists in
// localStorage; the inline head script in Base.astro sets it before paint.
---

<button class="btn" type="button" data-theme-toggle aria-label="Toggle black / white theme">
  theme: <span data-theme-label>black</span>
</button>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const label = document.querySelector<HTMLElement>('[data-theme-label]');
  const root = document.documentElement;

  // default is black (dark) unless OS explicitly prefers light and nothing stored
  function current(): 'light' | 'dark' {
    const set = root.getAttribute('data-theme');
    if (set === 'light' || set === 'dark') return set;
    return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }
  const word = (t: 'light' | 'dark') => (t === 'dark' ? 'black' : 'white');

  function sync() { if (label) label.textContent = word(current()); }
  sync();

  btn?.addEventListener('click', () => {
    const next = current() === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch {}
    sync();
  });
</script>
