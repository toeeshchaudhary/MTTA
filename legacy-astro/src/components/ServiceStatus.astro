---
// MTA-style service-status panel. One row per navigable line, status pulled
// from each entry in lib/lines.ts.
import RouteBullet from './RouteBullet.astro';
import { LINES } from '../lib/lines';

const STATE_TEXT = { good: 'Good Service', work: 'Planned Work', delay: 'Delays' } as const;
const STATE_CLASS = { good: 'svc-good', work: 'svc-work', delay: 'svc-delay' } as const;

const order = ['writing', 'projects', 'likes', 'now'] as const;
---

<section class="svcboard" aria-label="Service status">
  <h2><span>▸ service status</span></h2>
  {
    order.map((k) => {
      const line = LINES[k];
      return (
        <div class="svc-row">
          <RouteBullet glyph={line.bullet} color={line.color} text={line.text} size="1.5rem" />
          <span class="svc-name">{line.label}</span>
          <span class={`svc-state ${STATE_CLASS[line.status]}`}>
            <span class="svc-dot" />
            {STATE_TEXT[line.status]}
          </span>
        </div>
      );
    })
  }
</section>
