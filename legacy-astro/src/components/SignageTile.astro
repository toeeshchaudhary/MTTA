---
// The MTA station-signage tile: rounded black card, white Helvetica name,
// inline route bullets. The core repeated unit of the brutalist system.
export type TileBullet = { glyph: string; color: string; text?: string };

interface Props {
  href: string;
  title: string;
  bullets?: TileBullet[];
  sub?: string;
  lg?: boolean;
  clip?: boolean;
  current?: boolean;
}
const { href, title, bullets = [], sub, lg = false, clip = false, current = false } = Astro.props;
---

<a class:list={['tile', { lg }]} href={href} aria-current={current ? 'page' : undefined}>
  {
    bullets.length > 0 && (
      <span class="bullets">
        {bullets.map((b) => (
          <span class="bullet" style={`background:${b.color};color:${b.text ?? '#fff'}`}>{b.glyph}</span>
        ))}
      </span>
    )
  }
  <span class="t-body">
    <span class:list={['t-name', { clip }]}>{title}</span>
    {sub && <span class="t-sub">{sub}</span>}
  </span>
</a>
