---
// Terminal / LED departure board. Recent writing + projects rendered as
// "next arrivals" — the terminal-rat signature. Reads content at build time.
import { getCollection } from 'astro:content';
import { LINES } from '../lib/lines';

const writing = await getCollection('writing', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
const projects = await getCollection('projects', ({ data }) => (import.meta.env.PROD ? !data.draft : true));

type Arrival = { line: 'writing' | 'projects'; title: string; href: string; date: Date };
const arrivals: Arrival[] = [
  ...writing.map((p) => ({ line: 'writing' as const, title: p.data.title, href: `/writing/${p.id}`, date: p.data.date })),
  ...projects.map((p) => ({ line: 'projects' as const, title: p.data.title, href: `/projects/${p.id}`, date: p.data.date })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

// fixed pseudo-countdown so builds are deterministic (newest arrives soonest)
const MINS = [0, 2, 5, 9, 14, 20];
const rows = arrivals.slice(0, 6).map((a, i) => ({ ...a, min: MINS[i] ?? 25 }));
---

<section class="depboard" aria-label="Next arrivals">
  <h2><span>▸ next arrivals</span> <span class="blink">● live</span></h2>
  {
    rows.length === 0 ? (
      <p style="color:#8a8f93;font-size:0.85rem">no trains scheduled — check back soon.</p>
    ) : (
      rows.map((r) => {
        const line = LINES[r.line];
        return (
          <div class="dep-row">
            <span class="dep-bull" style={`background:${line.color};color:${line.text}`}>{line.bullet}</span>
            <span class="dep-dest"><a href={r.href}>{r.title}</a></span>
            <span class="dep-min">{r.min === 0 ? 'Now' : <>{r.min}<small> min</small></>}</span>
          </div>
        );
      })
    )
  }
</section>
